# ============================================================
# AxonLink 本地私有配置模板
# 使用方法：
#   cp src/main/resources/application-local.yml.example \
#      src/main/resources/application-local.yml
# 然后根据当前运行环境选择对应配置块，另一块保持注释即可。
# 注意：application-local.yml 已加入 .gitignore，不会提交 Git。
# ============================================================

# ┌──────────────────────────────────────────────────────────┐
# │  环境 A：外网本地（开发/测试，默认）                       │
# │  图数据库：本地 Neo4j                                     │
# │  源码路径：macOS 本机                                     │
# └──────────────────────────────────────────────────────────┘
neo4j:
  enabled: true
  uri: bolt://127.0.0.1:7687
  username: neo4j
  password: axonlink123

project:
  workspace-roots: /Users/wangshanhe/Desktop/myproject/sunline/sunline

callgraph:
  include-packages: cn.sunline.ltts.busi

flowtran:
  datasource: local


# ┌──────────────────────────────────────────────────────────┐
# │  环境 B：内网 Linux（生产/联调）                           │
# │  图数据库：内网 Neo4j                                      │
# │  源码路径：/home/cbs/code                                 │
# │                                                          │
# │  使用方法：注释掉上方「环境 A」所有内容，取消下方注释即可。 │
# └──────────────────────────────────────────────────────────┘
# neo4j:
#   enabled: true
#   uri: bolt://127.0.0.1:7687
#   username: neo4j
#   password: your-password
#
# project:
#   workspace-roots: /home/cbs/code
#
# callgraph:
#   include-packages: com.spdb.ccbs
#
# flowtran:
#   datasource: intranet
