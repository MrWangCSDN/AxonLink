# ============================================================
# AxonLink 本地私有配置模板
# 使用方法：
#   cp src/main/resources/application-local.yml.example \
#      src/main/resources/application-local.yml
# 然后根据当前运行环境选择对应配置块，另一块保持注释即可。
# 注意：application-local.yml 已加入 .gitignore，不会提交 Git。
# ============================================================

# ┌──────────────────────────────────────────────────────────┐
# │  环境 A：外网本地（开发/测试，默认）                       │
# │  图数据库：本地 Neo4j                                     │
# │  源码路径：macOS 本机                                     │
# └──────────────────────────────────────────────────────────┘
neo4j:
  enabled: true
  uri: bolt://127.0.0.1:7687
  username: neo4j
  password: axonlink123

project:
  workspace-roots: /Users/wangshanhe/Desktop/myproject/sunline/sunline

# ── 代码提交分析（Phase 8）────────────────────────────────────────────────────
# 默认关闭；投产时必须显式开启，否则定时扫描永远 no-op。
code-analysis:
  enabled: true
  # workspace-roots 下的直接子目录含 .git 则纳入每日扫描（增量模式）
  # 等价于环境变量 PROJECT_WORKSPACE_ROOTS；两者二选一即可。

callgraph:
  include-packages: cn.sunline.ltts.busi

flowtran:
  datasource: local

# ── DAO 索引巡检 / 结果库连接策略（外网本地必配）─────────────────────────────
# 结果库（MySQL benchmarkdb）与目标库（GaussDB targets.*）默认都指向内网地址，
# 外网本地连不上；不配置本项时 HikariCP 启动即 fail-fast，整个应用起不来。
# datasource-fail-fast=false → 惰性初始化：启动阶段完全不连库，应用照常启动；
# DII 巡检、代码提交统计、构建状态等依赖结果库的接口在真正访问时才报连接错误。
# 注：旧的 dao-index-analysis.enabled 总开关已于 2026-05 移除，配了也不生效。
dao-index-analysis:
  datasource-fail-fast: false

# 可选：外网期间顺手关掉构建状态轮询（默认开，连不上结果库时每 30s 刷一条失败日志）
# build-sync:
#   auto-phase:
#     enabled: false

benchmark:
  build-status:
    base-url: http://127.0.0.1:8080
    timeout-ms: 5000


# ┌──────────────────────────────────────────────────────────┐
# │  环境 B：内网 Linux（生产/联调）                           │
# │  图数据库：内网 Neo4j                                      │
# │  源码路径：/home/cbs/code                                 │
# │                                                          │
# │  使用方法：注释掉上方「环境 A」所有内容，取消下方注释即可。 │
# └──────────────────────────────────────────────────────────┘
# neo4j:
#   enabled: true
#   uri: bolt://127.0.0.1:7687
#   username: neo4j
#   password: your-password
#
# project:
#   workspace-roots: /home/cbs/code
#
# code-analysis:
#   enabled: true
#
# callgraph:
#   include-packages: com.spdb.ccbs
#
# flowtran:
#   datasource: intranet
#
# # dao-index-analysis：内网保持默认（datasource-fail-fast=true，启动时连库校验），无需配置
#
# benchmark:
#   build-status:
#     base-url: http://127.0.0.1:8080
#     timeout-ms: 5000


# ┌──────────────────────────────────────────────────────────┐
# │  AI 代码解读模块（内网 aihub / GLM-4.7）                  │
# │                                                          │
# │  ⚠️ 关键配置注意：                                        │
# │    1. base-url 只到端口，不要再带 /v1                     │
# │       （chat-path 里已经有 /v1，否则 /v1/v1 重复）        │
# │    2. model 是 glm-47（aihub 注册的 id，无点号）          │
# │    3. chat-path 保持 /v1/chat/completions 不变            │
# └──────────────────────────────────────────────────────────┘
# ai:
#   analysis:
#     enabled: true
#     provider: aihub
#     request-timeout-seconds: 180
#     glm5:
#       base-url: http://aihub.spdbdev.com:3000
#       api-key: sk-你的key
#       model: glm-47
#       chat-path: /v1/chat/completions
#       # stream=true：前端能看到字一个个蹦出来；false：loading 后整段出现。两种都可用。
#       stream: true
#       temperature: 0.2
#       max-tokens: 4096
