# 复制为 application-local.yml 后填写真实值（application-local.yml 已加入 .gitignore，不会提交）
#
#   cp src/main/resources/application-local.yml.example src/main/resources/application-local.yml

spring:
  datasource:
    url: jdbc:mysql://your-host:3306/your_db?useUnicode=true&characterEncoding=utf8&zeroDateTimeBehavior=convertToNull&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai&allowMultiQueries=true&rewriteBatchedStatements=true
    username: your_user
    password: your_password

project:
  # 多工程聚合目录（推荐）：自动扫描其下所有子模块的 src/main/java
  workspace-roots: /path/to/your/workspace-root
  # 若只有一个 Maven 模块，也可改用 source-roots 直接写两条路径：
  # source-roots: >-
  #   /path/to/one-module/src/main/java,
  #   /path/to/one-module/target/generated-sources/annotations
