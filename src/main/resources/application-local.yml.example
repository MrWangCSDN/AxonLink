# ============================================================
# AxonLink 本地私有配置模板
# 使用方法：
#   cp src/main/resources/application-local.yml.example \
#      src/main/resources/application-local.yml
# 然后根据当前运行环境选择对应配置块，另一块保持注释即可。
# 注意：application-local.yml 已加入 .gitignore，不会提交 Git。
# ============================================================

# ┌──────────────────────────────────────────────────────────┐
# │  环境 A：外网本地（开发/测试，默认）                       │
# │  数据库：阿里云 RDS  mall_admin                           │
# │  源码路径：macOS 本机                                     │
# └──────────────────────────────────────────────────────────┘
spring:
  datasource:
    url: jdbc:mysql://rm-uf65l2bqe8kpu0e219o.mysql.rds.aliyuncs.com:3306/mall_admin?useUnicode=true&characterEncoding=utf8&zeroDateTimeBehavior=convertToNull&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai&allowMultiQueries=true&rewriteBatchedStatements=true
    username: mall
    password: Liang@201314

project:
  workspace-roots: /Users/wangshanhe/Desktop/myproject/sunline/sunline

callgraph:
  enabled: true
  include-packages: cn.sunline.ltts.busi

flowtran:
  datasource: local          # local=mall_admin（外网本地） | intranet=benchmarkdb（内网）


